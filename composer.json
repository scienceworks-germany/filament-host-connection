{
    "name": "scienceworks/filament-host-connection",
    "description": "Shared host-pairing primitives: HTTP connect/poll/disconnect, status storage, and a reusable Filament form section. Used by filament-site-monitor and filament-zadarma.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "filament/filament": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "ScienceWorks\\HostConnection\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ScienceWorks\\HostConnection\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ScienceWorks\\HostConnection\\HostConnectionServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
